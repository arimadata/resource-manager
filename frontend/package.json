{
  "name": "@arimadata/resource-manager",
  "description": "A React resource manager with event-driven architecture and keyboard shortcuts. Designed to resemble Dropbox, it provides a complete interface for managing files and folders with built-in hooks for database persistence.",
  "private": false,
  "version": "0.1.6",
  "type": "module",
  "main": "dist/resource-manager.cjs.js",
  "module": "dist/resource-manager.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/resource-manager.es.js",
      "require": "./dist/resource-manager.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "semantic-release": "semantic-release"
  },
  "dependencies": {
    "react-collapsed": "^4.2.0",
    "react-icons": "^5.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "axios": "^1.7.7",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sass": "^1.77.6",
    "semantic-release": "^24.1.0",
    "vite": "^5.4.6"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arimadata/resource-manager.git"
  },
  "keywords": [
    "react",
    "dropbox-like",
    "resource manager",
    "list view"
  ],
  "author": "Arima",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/arimadata/resource-manager/issues"
  },
  "homepage": "https://github.com/arimadata/resource-manager#readme"
}
